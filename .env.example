# Browser-safe keys only. Get these from Supabase Dashboard > Settings > API.
# The anon key is a JWT starting with "eyJ..." — it is safe for the browser.
# Do NOT put service_role keys, database passwords, or project passwords here.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
