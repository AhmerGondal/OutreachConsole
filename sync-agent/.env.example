# Yahoo IMAP credentials (App Password, NOT your login password)
# Generate at: https://login.yahoo.com/account/security/app-passwords
YAHOO_EMAIL=you@yahoo.com
YAHOO_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Supabase — service role key (server-only, NEVER in browser)
# Get from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# The email address of the user account in the app
SYNC_TARGET_EMAIL=you@example.com
